# =============================================================
# .env.example - TallerAPI
#
# Plantilla SIN valores reales. Copia este fichero a ".env" en la
# raíz del proyecto (junto a docker-compose.yml) y sustituye cada
# valor por el tuyo. El fichero ".env" NO debe versionarse nunca
# (añádelo a .gitignore si no lo está ya).
#
# docker-compose lee automáticamente un fichero llamado ".env" en el
# mismo directorio donde se ejecuta "docker compose up".
# =============================================================

# --- Base de datos PostgreSQL ---
# Usadas tanto para inicializar el contenedor de PostgreSQL como para
# que la app sepa con qué credenciales conectarse a él.
DB_NAME=tallerapi
DB_USERNAME=tallerapi
DB_PASSWORD=sustituye-por-una-contrasena-segura

# --- Perfil de Spring activo dentro del contenedor ---
# "dev" para desarrollo local (SQL visible en logs, más verboso).
# "prod" cuando se prepare el despliegue en AWS (Fase 4).
SPRING_PROFILES_ACTIVE=dev

# --- JWT ---
# Genera un secreto largo y aleatorio, no uses el valor de ejemplo de
# application.yml. Por ejemplo: openssl rand -base64 48
JWT_SECRET=sustituye-por-un-secreto-largo-y-aleatorio
JWT_EXPIRATION_MS=3600000
